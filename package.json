{
  "name": "t-minus-tracker",
  "private": true,
  "description": "T-Minus Orbital Link: Real-time mission tracking and space telemetry monorepo.",
  "author": "F. Javier del Castillo Ramírez",
  "license": "CC-BY-NC-4.0",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjavidcr/t-minus-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/fjavidcr/t-minus-tracker/issues"
  },
  "homepage": "https://t-minus.fjdcr.dev",
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules .turbo .nuxt .output dist",
    "deploy:webapp": "vercel --prod",
    "deploy:landing": "pnpm run build --filter=@t-minus/landing && wrangler pages deploy apps/landing/dist --project-name=t-minus-landing",
    "deploy:all": "pnpm run deploy:webapp && pnpm run deploy:landing",
    "scan:secrets": "trufflehog git file://. && echo \"\" && trufflehog filesystem . --exclude-paths=.trufflehog-ignore",
    "audit:deps": "pnpm audit --audit-level high"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^9.21.0",
    "jiti": "^2.6.1",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.1.2",
    "typescript": "^5.9.3",
    "vercel": "^41.7.8",
    "wrangler": "^3.114.17"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.2"
    },
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  }
}
