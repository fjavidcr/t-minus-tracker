{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".nuxt/**",
        ".output/**",
        "dist/**",
        ".astro/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "src/**/*.astro",
        "tsconfig.json",
        "package.json"
      ]
    },
    "lint": {
      "inputs": [
        "eslint.config.js",
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "src/**/*.astro",
        "package.json"
      ]
    },
    "format": {
      "inputs": [
        "**/*.{js,ts,tsx,vue,astro,json,md,css}",
        "!**/dist/**",
        "!**/.nuxt/**",
        "!**/.output/**",
        "!**/node_modules/**"
      ]
    }
  }
}
