---
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: 'Agencies', value: '150+' },
  { label: 'Live Data', value: '24/7' },
  { label: 'Accuracy', value: '99.9%' },
];
---

<Layout
	title="T-Minus | Real-time Orbital Link & Space Intelligence"
	description="Accede a telemetría en tiempo real, seguimiento de lanzamientos y datos orbitales detallados con el centro de mando T-Minus. Diseñado para entusiastas del espacio."
>
	<main class="relative overflow-hidden">
		<!-- Background Glows -->
		<div class="fixed top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-indigo-600/10 blur-[120px] rounded-full -z-10"></div>
		<div class="fixed bottom-0 right-0 w-[400px] h-[400px] bg-sky-500/5 blur-[100px] rounded-full -z-10"></div>

		<!-- Nav -->
		<nav class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/50 backdrop-blur-xl">
			<div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
				<div class="flex items-center gap-2 group cursor-pointer">
					<div class="w-8 h-8 rounded-lg overflow-hidden transition-transform group-hover:rotate-12 border border-white/10">
						<img src="/logo.webp" alt="T-Minus Logo" class="w-full h-full object-cover" />
					</div>
					<span class="font-bold text-xl tracking-tight text-white uppercase font-['Space_Grotesk']">T-Minus</span>
				</div>
				<a
					href="https://app.t-minus.fjdcr.dev"
					class="bg-white/5 hover:bg-white/10 px-4 py-2 rounded-full text-sm font-medium border border-white/10 transition-all hover:scale-105 active:scale-95"
				>
					Acceder a la App
				</a>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="max-w-7xl mx-auto px-4 pt-20 pb-16 md:pt-32 md:pb-32 text-center">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-semibold text-indigo-400 mb-8 animate-fade-in">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
				</span>
				SISTEMA DE ENLACE ORBITAL ACTIVO
			</div>

			<h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-8 leading-[1.1] tracking-tight bg-linear-to-b from-white to-slate-400 bg-clip-text text-transparent font-['Space_Grotesk']">
				Toda la órbita,<br />en tiempo real.
			</h1>

			<p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-400 mb-12">
				Monitoriza lanzamientos, telemetría de misiones y specs técnicas con una interfaz cinemática diseñada para la exploración moderna.
			</p>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a
					href="https://app.t-minus.fjdcr.dev"
					class="w-full sm:w-auto px-8 py-4 bg-indigo-600 hover:bg-indigo-500 rounded-2xl font-bold text-white transition-all hover:shadow-[0_0_40px_rgba(79,70,229,0.4)] hover:scale-105 active:scale-95 flex items-center justify-center gap-2"
				>
					Entrar al Centro de Mando
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
				</a>
				<a
					href="#features"
					class="w-full sm:w-auto px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl font-bold text-white transition-all"
				>
					Ver Características
				</a>
			</div>

			<!-- Stats -->
			<div class="grid grid-cols-3 gap-4 max-w-2xl mx-auto mt-24 border border-white/5 bg-slate-900/30 backdrop-blur-sm p-6 rounded-3xl">
				{stats.map(stat => (
					<div class="text-center">
						<div class="text-2xl md:text-3xl font-bold text-white font-['Space_Grotesk']">{stat.value}</div>
						<div class="text-[10px] md:text-xs text-slate-500 uppercase tracking-widest font-bold mt-1">{stat.label}</div>
					</div>
				))}
			</div>
		</section>

		<!-- Features -->
		<section id="features" class="max-w-7xl mx-auto px-4 py-24 border-t border-white/5">
			<div class="grid md:grid-cols-3 gap-8">
				<div class="group p-8 rounded-3xl bg-slate-900/20 border border-white/5 transition-all hover:bg-slate-900/40 hover:border-indigo-500/30">
					<div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-4 font-['Space_Grotesk'] uppercase tracking-tight">Telemetría en Vivo</h3>
					<p class="text-slate-400 leading-relaxed">Accede a datos actualizados de misiones espaciales en curso con latencia mínima y visualización avanzada.</p>
				</div>

				<div class="group p-8 rounded-3xl bg-slate-900/20 border border-white/5 transition-all hover:bg-slate-900/40 hover:border-sky-500/30">
					<div class="w-12 h-12 bg-sky-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-4.44-5.126c.303.47.605.941.905 1.411A13.91 13.91 0 013.844 12c0-2.484.646-4.755 1.776-6.713m4.441 12.37A14.01 14.01 0 0113.844 14c0-2.264-.492-4.417-1.378-6.354m1.378 12.067A14.01 14.01 0 0019.556 12a14.01 14.01 0 00-5.712-11.378" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-4 font-['Space_Grotesk'] uppercase tracking-tight">Enlace Seguro</h3>
					<p class="text-slate-400 leading-relaxed">Implementamos protocolos HMAC y seguridad de grado militar para proteger el acceso a datos orbitales sensibles.</p>
				</div>

				<div class="group p-8 rounded-3xl bg-slate-900/20 border border-white/5 transition-all hover:bg-slate-900/40 hover:border-purple-500/30">
					<div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-2" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-4 font-['Space_Grotesk'] uppercase tracking-tight">Archivo Histórico</h3>
					<p class="text-slate-400 leading-relaxed">Explora miles de misiones pasadas con specs detalladas, imágenes y resultados históricos completos.</p>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="max-w-7xl mx-auto px-4 py-12 border-t border-white/5 text-center">
			<p class="text-slate-500 text-sm mb-4">
				© {new Date().getFullYear()} T-Minus. Diseñado para la exploración espacial moderna.
			</p>
			<div class="flex justify-center gap-6">
				<a href="#" class="text-slate-400 hover:text-white transition-colors">Términos</a>
				<a href="#" class="text-slate-400 hover:text-white transition-colors">Privacidad</a>
				<a href="#" class="text-slate-400 hover:text-white transition-colors">API</a>
			</div>
		</footer>
	</main>
</Layout>

<style>
	@keyframes fade-in {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fade-in 0.6s ease-out forwards;
	}
</style>
