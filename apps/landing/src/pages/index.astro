---
import Layout from '../layouts/Layout.astro';
import { Button, StatusIndicator, TelemetryStatus } from '@t-minus/ui';

// Mock data for the landing page demonstration
const missionStatus = {
  cachedAt: Date.now(),
  maxAge: 3600,
  label: 'Orbital Link Status'
};

const stats = [
  { label: 'Agencies', value: '150+' },
  { label: 'Live Data', value: '24/7' },
  { label: 'Accuracy', value: '99.9%' },
];
---

<Layout
	title="T-Minus | Your Landing in Deep Space"
	description="Bienvenido al centro de mando orbital. No es solo una landing page, es tu punto de entrada (landing) a la telemetría espacial en tiempo real."
>
	<main class="relative min-h-screen overflow-hidden selection:bg-artemis-orange/30">
		<!-- Background Glows (Shared Cinematic Style) -->
		<div class="fixed top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-nasa-blue/10 blur-[120px] rounded-full -z-10"></div>
		<div class="fixed bottom-0 right-0 w-[400px] h-[400px] bg-artemis-orange/5 blur-[100px] rounded-full -z-10"></div>

		<!-- Nav -->
		<nav class="sticky top-0 z-50 border-b border-outline-variant/10 bg-surface/80 backdrop-blur-2xl">
			<div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
				<div class="flex items-center gap-4 group cursor-pointer">
					<div class="w-10 h-10 rounded-xl overflow-hidden border border-outline-variant/10 transition-transform group-hover:scale-105 shadow-lg">
						<img src="/logo.webp" alt="T-Minus Logo" class="w-full h-full object-cover" />
					</div>
					<div class="flex flex-col leading-none">
						<span class="font-black text-2xl tracking-tighter text-foreground uppercase font-headline">T-Minus</span>
						<span class="text-[0.6rem] font-bold uppercase tracking-[0.3em] text-on-surface-variant font-label mt-1">Orbital Command</span>
					</div>
				</div>
				
				<div class="hidden md:block">
					<TelemetryStatus client:load {...missionStatus} />
				</div>

				<Button variant="outline" class="rounded-full px-6 font-label text-[10px] uppercase tracking-widest border-outline-variant/20 hover:border-nasa-blue/40" as="a" href="https://app.t-minus.fjdcr.dev">
					Deep Space App
				</Button>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="max-w-7xl mx-auto px-4 pt-24 pb-16 md:pt-40 md:pb-32 text-center relative">
			<!-- Play on words: The Landing -->
			<div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-surface-container border border-outline-variant/10 text-[10px] font-black tracking-[0.2em] text-artemis-orange mb-12 animate-fade-in shadow-xl">
				<StatusIndicator client:load status="active" class="h-1.5 w-1.5" />
				SISTEMA DE ATERRIZAJE (LANDING) PREPARADO
			</div>

			<h1 class="text-6xl md:text-8xl lg:text-9xl font-black mb-8 leading-[0.9] tracking-tighter font-headline uppercase italic">
				<span class="text-foreground">Prepara tu</span><br />
				<span class="mission-text-stroke">Aterrizaje.</span>
			</h1>

			<p class="max-w-2xl mx-auto text-lg md:text-2xl text-on-surface-variant mb-12 font-body leading-relaxed">
				No es solo una <span class="text-foreground font-bold">Landing Page</span>. Es el punto de re-entrada a la telemetría orbital más precisa del sistema solar. 
			</p>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-6">
				<Button size="lg" class="w-full sm:w-auto h-14 px-10 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-[0_20px_50px_rgba(11,61,145,0.3)] hover:shadow-nasa-blue/50" as="a" href="https://app.t-minus.fjdcr.dev">
					Iniciar Propulsión
				</Button>
				<Button variant="ghost" size="lg" class="w-full sm:w-auto h-14 px-10 rounded-2xl font-black text-xs uppercase tracking-[0.2em] text-on-surface-variant hover:text-foreground" as="a" href="#features">
					Ver Telemetría
				</Button>
			</div>

			<!-- Stats -->
			<div class="grid grid-cols-3 gap-8 max-w-3xl mx-auto mt-32 border border-outline-variant/10 bg-surface-container/30 backdrop-blur-md p-8 rounded-[40px] shadow-2xl relative overflow-hidden group">
				<div class="absolute inset-0 bg-nasa-blue/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
				{stats.map(stat => (
					<div class="text-center relative z-10">
						<div class="text-3xl md:text-4xl font-black text-foreground font-headline tracking-tighter">{stat.value}</div>
						<div class="text-[9px] text-on-surface-variant/60 uppercase tracking-[0.3em] font-black mt-2 font-label italic">{stat.label}</div>
					</div>
				))}
			</div>
		</section>

		<!-- Features Grid (Cinematic) -->
		<section id="features" class="max-w-7xl mx-auto px-4 py-32 border-t border-outline-variant/5">
			<div class="grid md:grid-cols-3 gap-12">
				<div class="group p-10 rounded-[40px] bg-surface-container-low border border-outline-variant/5 transition-all hover:border-nasa-blue/20 hover:scale-[1.02]">
					<div class="w-14 h-14 bg-nasa-blue/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-nasa-blue/20 transition-colors">
						<svg class="w-7 h-7 text-nasa-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
						</svg>
					</div>
					<h3 class="text-2xl font-black text-foreground mb-4 font-headline uppercase tracking-tight italic">Propulsión en Vivo</h3>
					<p class="text-on-surface-variant font-body leading-relaxed text-sm">Telemetría de misiones activas con latencia reducida. Siente cada etapa del lanzamiento desde tu navegador.</p>
				</div>

				<div class="group p-10 rounded-[40px] bg-surface-container-low border border-outline-variant/5 transition-all hover:border-artemis-orange/20 hover:scale-[1.02]">
					<div class="w-14 h-14 bg-artemis-orange/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-artemis-orange/20 transition-colors">
						<svg class="w-7 h-7 text-artemis-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-4.44-5.126c.303.47.605.941.905 1.411A13.91 13.91 0 013.844 12c0-2.484.646-4.755 1.776-6.713m4.441 12.37A14.01 14.01 0 0113.844 14c0-2.264-.492-4.417-1.378-6.354m1.378 12.067A14.01 14.01 0 0019.556 12a14.01 14.01 0 00-5.712-11.378" />
						</svg>
					</div>
					<h3 class="text-2xl font-black text-foreground mb-4 font-headline uppercase tracking-tight italic">Protocolos HMAC</h3>
					<p class="text-on-surface-variant font-body leading-relaxed text-sm">Seguridad de grado orbital. Tus consultas de datos están protegidas por enlaces criptográficos seguros.</p>
				</div>

				<div class="group p-10 rounded-[40px] bg-surface-container-low border border-outline-variant/5 transition-all hover:border-nasa-blue/20 hover:scale-[1.02]">
					<div class="w-14 h-14 bg-nasa-blue/10 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-nasa-blue/20 transition-colors">
						<svg class="w-7 h-7 text-nasa-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
						</svg>
					</div>
					<h3 class="text-2xl font-black text-foreground mb-4 font-headline uppercase tracking-tight italic">Landing Log</h3>
					<p class="text-on-surface-variant font-body leading-relaxed text-sm">Historial completo de aterrizajes y despliegues. Analiza el éxito de cada misión histórica.</p>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="max-w-7xl mx-auto px-4 py-20 border-t border-outline-variant/10 text-center">
			<div class="inline-block p-4 rounded-3xl bg-surface-container-low border border-outline-variant/5 mb-8">
				<img src="/logo.webp" alt="T-Minus Logo" class="w-8 h-8 opacity-50 grayscale" />
			</div>
			<p class="text-on-surface-variant text-xs uppercase tracking-[0.4em] font-black mb-8 italic">
				T-Minus Orbital Command Centre
			</p>
			<div class="flex justify-center gap-8 text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant/40">
				<a href="#" class="hover:text-primary transition-colors">© {new Date().getFullYear()} Archive</a>
				<a href="#" class="hover:text-primary transition-colors">Privacy Link</a>
				<a href="#" class="hover:text-primary transition-colors">Secure API</a>
			</div>
		</footer>
	</main>
</Layout>
