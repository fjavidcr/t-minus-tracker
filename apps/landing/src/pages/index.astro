---
import { Button, StatusIndicator, TelemetryStatus } from '@t-minus/ui'

import Layout from '../layouts/Layout.astro'

// Mock data for the landing page demonstration
const missionStatus = {
  cachedAt: Date.now(),
  label: 'Orbital Link Status',
  maxAge: 3600
}

const stats = [
  { label: 'Agencies', value: '150+' },
  { label: 'Live Data', value: '24/7' },
  { label: 'Accuracy', value: '99.9%' }
]
---

<Layout
  description="Bienvenido al centro de mando orbital. No es solo una landing page, es tu punto de entrada (landing) a la telemetría espacial en tiempo real."
  title="T-Minus | Your Landing in Deep Space"
>
  <main class="selection:bg-artemis-orange/30 relative min-h-screen overflow-hidden">
    <!-- Background Glows (Shared Cinematic Style) -->
    <div
      class="bg-nasa-blue/10 fixed left-1/2 top-0 -z-10 h-[600px] w-full -translate-x-1/2 rounded-full blur-[120px]"
    >
    </div>
    <div
      class="bg-artemis-orange/5 fixed bottom-0 right-0 -z-10 h-[400px] w-[400px] rounded-full blur-[100px]"
    >
    </div>

    <!-- Nav -->
    <nav
      class="border-outline-variant/10 bg-surface/80 sticky top-0 z-50 border-b backdrop-blur-2xl"
    >
      <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4">
        <div class="group flex cursor-pointer items-center gap-4">
          <div
            class="border-outline-variant/10 h-10 w-10 overflow-hidden rounded-xl border shadow-lg transition-transform group-hover:scale-105"
          >
            <img alt="T-Minus Logo" class="h-full w-full object-cover" src="/logo.webp" />
          </div>
          <div class="flex flex-col leading-none">
            <span
              class="text-foreground font-headline text-2xl font-black uppercase tracking-tighter"
              >T-Minus</span
            >
            <span
              class="text-on-surface-variant font-label mt-1 text-[0.6rem] font-bold uppercase tracking-[0.3em]"
              >Orbital Command</span
            >
          </div>
        </div>

        <div class="hidden md:block">
          <TelemetryStatus client:load {...missionStatus} />
        </div>

        <Button
          as="a"
          class="font-label border-outline-variant/20 hover:border-nasa-blue/40 rounded-full px-6 text-[10px] uppercase tracking-widest"
          href="https://app.t-minus.fjdcr.dev"
          variant="outline"
        >
          Deep Space App
        </Button>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative mx-auto max-w-7xl px-4 pb-16 pt-24 text-center md:pb-32 md:pt-40">
      <!-- Play on words: The Landing -->
      <div
        class="bg-surface-container border-outline-variant/10 text-artemis-orange animate-fade-in mb-12 inline-flex items-center gap-3 rounded-full border px-4 py-2 text-[10px] font-black tracking-[0.2em] shadow-xl"
      >
        <StatusIndicator class="h-1.5 w-1.5" client:load status="active" />
        SISTEMA DE ATERRIZAJE (LANDING) PREPARADO
      </div>

      <h1
        class="font-headline mb-8 text-6xl font-black uppercase italic leading-[0.9] tracking-tighter md:text-8xl lg:text-9xl"
      >
        <span class="text-foreground">Prepara tu</span><br />
        <span class="mission-text-stroke">Aterrizaje.</span>
      </h1>

      <p
        class="text-on-surface-variant font-body mx-auto mb-12 max-w-2xl text-lg leading-relaxed md:text-2xl"
      >
        No es solo una <span class="text-foreground font-bold">Landing Page</span>. Es el punto de
        re-entrada a la telemetría orbital más precisa del sistema solar.
      </p>

      <div class="flex flex-col items-center justify-center gap-6 sm:flex-row">
        <Button
          as="a"
          class="hover:shadow-nasa-blue/50 h-14 w-full rounded-2xl px-10 text-xs font-black uppercase tracking-[0.2em] shadow-[0_20px_50px_rgba(11,61,145,0.3)] sm:w-auto"
          href="https://app.t-minus.fjdcr.dev"
          size="lg"
        >
          Iniciar Propulsión
        </Button>
        <Button
          as="a"
          class="text-on-surface-variant hover:text-foreground h-14 w-full rounded-2xl px-10 text-xs font-black uppercase tracking-[0.2em] sm:w-auto"
          href="#features"
          size="lg"
          variant="ghost"
        >
          Ver Telemetría
        </Button>
      </div>

      <!-- Stats -->
      <div
        class="border-outline-variant/10 bg-surface-container/30 group relative mx-auto mt-32 grid max-w-3xl grid-cols-3 gap-8 overflow-hidden rounded-[40px] border p-8 shadow-2xl backdrop-blur-md"
      >
        <div
          class="bg-nasa-blue/5 absolute inset-0 opacity-0 transition-opacity group-hover:opacity-100"
        >
        </div>
        {
          stats.map((stat) => (
            <div class="relative z-10 text-center">
              <div class="text-foreground font-headline text-3xl font-black tracking-tighter md:text-4xl">
                {stat.value}
              </div>
              <div class="text-on-surface-variant/60 font-label mt-2 text-[9px] font-black uppercase italic tracking-[0.3em]">
                {stat.label}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Features Grid (Cinematic) -->
    <section class="border-outline-variant/5 mx-auto max-w-7xl border-t px-4 py-32" id="features">
      <div class="grid gap-12 md:grid-cols-3">
        <div
          class="bg-surface-container-low border-outline-variant/5 hover:border-nasa-blue/20 group rounded-[40px] border p-10 transition-all hover:scale-[1.02]"
        >
          <div
            class="bg-nasa-blue/10 group-hover:bg-nasa-blue/20 mb-8 flex h-14 w-14 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-nasa-blue h-7 w-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M13 10V3L4 14h7v7l9-11h-7z"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"></path>
            </svg>
          </div>
          <h3
            class="text-foreground font-headline mb-4 text-2xl font-black uppercase italic tracking-tight"
          >
            Propulsión en Vivo
          </h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">
            Telemetría de misiones activas con latencia reducida. Siente cada etapa del lanzamiento
            desde tu navegador.
          </p>
        </div>

        <div
          class="bg-surface-container-low border-outline-variant/5 hover:border-artemis-orange/20 group rounded-[40px] border p-10 transition-all hover:scale-[1.02]"
        >
          <div
            class="bg-artemis-orange/10 group-hover:bg-artemis-orange/20 mb-8 flex h-14 w-14 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-artemis-orange h-7 w-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-4.44-5.126c.303.47.605.941.905 1.411A13.91 13.91 0 013.844 12c0-2.484.646-4.755 1.776-6.713m4.441 12.37A14.01 14.01 0 0113.844 14c0-2.264-.492-4.417-1.378-6.354m1.378 12.067A14.01 14.01 0 0019.556 12a14.01 14.01 0 00-5.712-11.378"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"></path>
            </svg>
          </div>
          <h3
            class="text-foreground font-headline mb-4 text-2xl font-black uppercase italic tracking-tight"
          >
            Protocolos HMAC
          </h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">
            Seguridad de grado orbital. Tus consultas de datos están protegidas por enlaces
            criptográficos seguros.
          </p>
        </div>

        <div
          class="bg-surface-container-low border-outline-variant/5 hover:border-nasa-blue/20 group rounded-[40px] border p-10 transition-all hover:scale-[1.02]"
        >
          <div
            class="bg-nasa-blue/10 group-hover:bg-nasa-blue/20 mb-8 flex h-14 w-14 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-nasa-blue h-7 w-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"></path>
            </svg>
          </div>
          <h3
            class="text-foreground font-headline mb-4 text-2xl font-black uppercase italic tracking-tight"
          >
            Landing Log
          </h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">
            Historial completo de aterrizajes y despliegues. Analiza el éxito de cada misión
            histórica.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-outline-variant/10 mx-auto max-w-7xl border-t px-4 py-20 text-center">
      <div
        class="bg-surface-container-low border-outline-variant/5 mb-8 inline-block rounded-3xl border p-4"
      >
        <img alt="T-Minus Logo" class="h-8 w-8 opacity-50 grayscale" src="/logo.webp" />
      </div>
      <p class="text-on-surface-variant mb-8 text-xs font-black uppercase italic tracking-[0.4em]">
        T-Minus Orbital Command Centre
      </p>
      <div
        class="text-on-surface-variant/40 flex justify-center gap-8 text-[10px] font-bold uppercase tracking-[0.2em]"
      >
        <a class="hover:text-primary transition-colors" href="#"
          >© {new Date().getFullYear()} Archive</a
        >
        <a class="hover:text-primary transition-colors" href="#">Privacy Link</a>
        <a class="hover:text-primary transition-colors" href="#">Secure API</a>
      </div>
    </footer>
  </main>
</Layout>
